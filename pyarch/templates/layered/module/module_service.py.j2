from sqlalchemy.orm import Session

from app.models.{{ module_name }} import {{ model_name }}
from app.repositories import {{ module_name }} as {{ module_name }}_repository
from app.schemas.{{ module_name }} import {{ model_name }}Create, {{ model_name }}Update


class {{ model_name }}NotFoundError(LookupError):
    def __init__(self, item_id: int) -> None:
        super().__init__(f"{{ model_name }} with id={item_id} was not found")


def add_item(db: Session, payload: {{ model_name }}Create) -> {{ model_name }}:
    try:
        item = {{ module_name }}_repository.add_item(
            db,
            payload.model_dump(),
        )
        db.commit()
        db.refresh(item)
        return item
    except Exception:
        db.rollback()
        raise


def get_items(
    db: Session,
    *,
    offset: int = 0,
    limit: int = 100,
) -> list[{{ model_name }}]:
    return {{ module_name }}_repository.get_items(
        db,
        offset=offset,
        limit=limit,
    )


def get_item(db: Session, item_id: int) -> {{ model_name }}:
    item = {{ module_name }}_repository.get_item(db, item_id)
    if item is None:
        raise {{ model_name }}NotFoundError(item_id)
    return item


def patch_item(
    db: Session,
    item_id: int,
    payload: {{ model_name }}Update,
) -> {{ model_name }}:
    item = get_item(db, item_id)

    try:
        updated_item = {{ module_name }}_repository.patch_item(
            db,
            item,
            payload.model_dump(exclude_unset=True),
        )
        db.commit()
        db.refresh(updated_item)
        return updated_item
    except Exception:
        db.rollback()
        raise


def delete_item(db: Session, item_id: int) -> None:
    item = get_item(db, item_id)

    try:
        {{ module_name }}_repository.delete_item(db, item)
        db.commit()
    except Exception:
        db.rollback()
        raise
